# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://mythra:mythra@cluster0.1inrm0b.mongodb.net/smart_attendance?retryWrites=true&w=majority&appName=Cluster0

# ─── Redis (optional for local dev — set REDIS_ENABLED=false to skip) ─────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=local-dev-secret-32-bytes-minimum!!
JWT_REFRESH_SECRET=local-dev-refresh-secret-32bytes!
BCRYPT_ROUNDS=10

# ─── Email (disabled for local dev) ──────────────────────────────────────────
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=noreply@localhost.dev
SENDGRID_API_KEY=disabled-for-local-dev

# ─── AWS (disabled for local dev) ────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local-dev
AWS_SECRET_ACCESS_KEY=local-dev
S3_BUCKET=local-dev-bucket

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
