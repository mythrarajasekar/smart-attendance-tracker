# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (from Secrets Manager in production)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/smart_attendance?retryWrites=true&w=majority

# ─── Redis (ElastiCache) ──────────────────────────────────────────────────────
REDIS_HOST=<elasticache-endpoint>.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=<auth-token-from-secrets-manager>

# ─── Authentication ───────────────────────────────────────────────────────────
# MINIMUM 32 bytes (256 bits) of cryptographic randomness
# Generate with: openssl rand -base64 32
JWT_SECRET=<generate-with-openssl-rand-base64-32>
JWT_REFRESH_SECRET=<generate-with-openssl-rand-base64-32>
BCRYPT_ROUNDS=12

# ─── Email ────────────────────────────────────────────────────────────────────
# Options: sendgrid | ses
EMAIL_PROVIDER=ses
EMAIL_FROM=noreply@attendance.edu

# SendGrid (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=<from-secrets-manager>

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# In ECS: use IAM task role (no access key needed)
# For local dev only:
# AWS_ACCESS_KEY_ID=<local-dev-only>
# AWS_SECRET_ACCESS_KEY=<local-dev-only>

# ─── S3 (Profile Photos) ─────────────────────────────────────────────────────
S3_BUCKET=sat-profiles-prod
# S3_ENDPOINT=  # Leave empty for AWS S3; set for MinIO local dev

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://attendance.edu,https://www.attendance.edu

# ─── Frontend (for reference) ────────────────────────────────────────────────
REACT_APP_API_URL=https://api.attendance.edu/api/v1
    