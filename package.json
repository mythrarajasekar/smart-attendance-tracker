{
  "name": "smart-attendance-tracker",
  "version": "1.0.0",
  "description": "Smart Attendance Tracker — Production-grade web application for college attendance management",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "type-check": "tsc -b",
    "lint": "eslint -c .eslintrc.json src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest --runInBand",
    "test:unit": "jest --testPathPattern='__tests__/(.*\\.service|.*\\.middleware|.*\\.pbt)\\.test\\.ts' --runInBand",
    "test:integration": "jest --testPathPattern='__tests__/.*\\.integration\\.test\\.ts' --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:ci": "jest --ci --runInBand --forceExit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.511.0",
    "@aws-sdk/client-ses": "3.511.0",
    "@aws-sdk/s3-request-presigner": "3.511.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@sendgrid/mail": "8.1.1",
    "bcrypt": "5.1.1",
    "cors": "2.8.5",
    "csv-parse": "5.5.3",
    "dotenv": "17.4.2",
    "exceljs": "4.4.0",
    "express": "4.18.2",
    "express-async-errors": "3.1.1",
    "express-rate-limit": "7.1.5",
    "helmet": "7.1.0",
    "ioredis": "5.3.2",
    "joi": "17.12.1",
    "jsonwebtoken": "9.0.2",
    "mongoose": "8.1.1",
    "multer": "1.4.5-lts.1",
    "node-cron": "3.0.3",
    "pdfkit": "0.15.0",
    "rate-limit-redis": "4.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.2",
    "sharp": "0.33.2",
    "uuid": "9.0.1",
    "winston": "3.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.11",
    "@types/jsonwebtoken": "9.0.5",
    "@types/morgan": "1.9.9",
    "@types/multer": "1.4.11",
    "@types/node": "20.11.5",
    "@types/node-cron": "3.0.11",
    "@types/pdfkit": "0.13.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "6.0.2",
    "@types/uuid": "9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "fast-check": "3.15.0",
    "jest": "29.7.0",
    "morgan": "1.10.0",
    "supertest": "6.3.4",
    "ts-jest": "29.1.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
